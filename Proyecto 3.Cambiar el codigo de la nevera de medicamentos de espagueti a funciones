// Pines I2C para la pantalla OLED
const int I2C_SDA = 8;
const int I2C_SCL = 9;

const int PIN_PUERTA = 15;
const int PIN_SENSOR = 7;


const int PIN_INC = 6;
const int PIN_DEC = 5;

//const float SETPOINT= 4.0;
float SETPOINT = 4.0;

unsigned long tiempoAnterior = 0;  //Una nueva avriable para manejar lo del tiempo anterior porques e va a utilizar la funcion millis()
const unsigned long INTERVALO_ACTUALIZACION = 1000; //Intervalo de actualizacion de segundo


//Variables para antirrebote
const unsigned long TIEMPO_ANTIRREBOTE = 200;  //***200 ms
unsigned long ultimoTiempoInc = 0;             //***calculo de tiempos antirrebote
unsigned long ultimoTiempoDec = 0;             //***calculo de tiempos antirrebote

volatile bool banderaInc = false;              //***variables adentro de las interrupciones.Varibles que pueden cambiar dentro de las interrupciones=volatiles.
volatile bool banderaDec = false;              //***variables adentro de las interrupciones.Varibles que pueden cambiar dentro de las interrupciones=volatiles.

float temperaturaActual = 4.0; //Variable global para que la funcion no tenga parametros
